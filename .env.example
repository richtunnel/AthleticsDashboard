# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/athletics_dashboard?schema=public"

# NextAuth Configuration
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Public App URL (used for callbacks and Stripe redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# IP Geolocation Provider (for login tracking)
IPINFO_API_TOKEN="your-ipinfo-api-token"

# Google OAuth & Calendar Integration
GOOGLE_CALENDAR_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CALENDAR_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/calendar-callback"

# Google Maps API (for address autocomplete)
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Google Distance Matrix API (for travel time calculations)
GOOGLE_DISTANCE_API_KEY="your-google-distance-api-key"

# OpenWeatherMap API (for weather conditions)
OPENWEATHER_API_KEY="your-openweather-api-key"

# Email Service (Resend)
NEXT_PUBLIC_RESEND_API_KEY="re_your_NEXT_PUBLIC_RESEND_API_KEY"
EMAIL_FROM="AD Hub <noreply@athleticdirectorhub.com>"

# Slack Notifications
SLACK_FEEDBACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

# Google Forms Integration (optional)
# If set, the feedback form will embed the Google Form instead of using the built-in form
# Example: https://docs.google.com/forms/d/e/YOUR_FORM_ID/viewform
GOOGLE_FORMS_FEEDBACK_URL=""

# Calendly Integration (optional)
# URL to your Calendly booking page for demo scheduling
# Example: https://calendly.com/your-username/demo
NEXT_PUBLIC_CALENDLY_URL="https://calendly.com/athleticdirectorhub/30min"

# Mixpanel Analytics (optional)
# For tracking user interactions, signups, and feature usage
# NEXT_PUBLIC_MIXPANEL_TOKEN: Your Mixpanel project token for client-side tracking
# MIXPANEL_SERVICE_SECRET: Your Mixpanel service account secret for server-side tracking
NEXT_PUBLIC_MIXPANEL_TOKEN="your-mixpanel-project-token"
MIXPANEL_SERVICE_SECRET="your-mixpanel-service-secret"

# OpenAI (for AI-powered travel recommendations)
OPENAI_API_KEY="sk-your-openai-api-key"

# OpenAI Domain PK (optional - for ChatKit embedding on trusted origins)
# This is for embedding OpenAI's ChatKit on specific domains
# OPENAI_DOMAIN_PK="domain_pk_your-domain-pk-key"

# Stripe Payment Processing
# For test mode, use keys starting with sk_test_ and whsec_
# For production, use keys starting with sk_live_
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Stripe Price IDs
STRIPE_STANDARD_PRICE_ID_MO="price_1SlbnJPoFQ98Rxs6mXNFsy2T"
STRIPE_STANDARD_PRICE_ID_YR="price_1SlbvRPoFQ98Rxs6hmfIGBlP"
STRIPE_TEAM_PRICE_ID_MO="price_1SjixuPoFQ98Rxs6SvUYQRXr"
STRIPE_TEAM_PRICE_ID_YR="price_1SjizePoFQ98Rxs6KGfct6Vf"
STRIPE_PLUS_PRICE_ID_MO="price_1Sjj0vPoFQ98Rxs60z0ultaq"
STRIPE_PLUS_PRICE_ID_YR="price_1Sjj1iPoFQ98Rxs62Vmsq848"

# Public Price IDs (needed for frontend)
NEXT_PUBLIC_STRIPE_STANDARD_PRICE_ID_MO="price_1SlbnJPoFQ98Rxs6mXNFsy2T"
NEXT_PUBLIC_STRIPE_STANDARD_PRICE_ID_YR="price_1SlbvRPoFQ98Rxs6hmfIGBlP"
NEXT_PUBLIC_STRIPE_TEAM_PRICE_ID_MO="price_1SjixuPoFQ98Rxs6SvUYQRXr"
NEXT_PUBLIC_STRIPE_TEAM_PRICE_ID_YR="price_1SjizePoFQ98Rxs6KGfct6Vf"
NEXT_PUBLIC_STRIPE_PLUS_PRICE_ID_MO="price_1Sjj0vPoFQ98Rxs60z0ultaq"
NEXT_PUBLIC_STRIPE_PLUS_PRICE_ID_YR="price_1Sjj1iPoFQ98Rxs62Vmsq848"

# Optional: Legacy Stripe IDs (for backward compatibility)
STRIPE_MONTHLY_PRICE_ID="price_1SlbnJPoFQ98Rxs6mXNFsy2T"
STRIPE_ANNUAL_PRICE_ID="price_1SlbvRPoFQ98Rxs6hmfIGBlP"

# Optional: Override trial period in test mode (in days, default: 14)
# Set to 1 for faster testing of trial expiration
STRIPE_TEST_TRIAL_DAY="14"
# STRIPE_TEST_TRIAL_DAYS="1"

# Account Cleanup Automation
CRON_SECRET="your-shared-cron-secret"
ACCOUNT_DELETION_GRACE_DAYS="14"
ACCOUNT_DELETION_REMINDER_DAYS="7,1"

# Environment
NODE_ENV="development"
