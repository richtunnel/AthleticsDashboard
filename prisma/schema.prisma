model Post {
  id           String        @id @default(cuid())
  content      String?
  authorId     String
  author       User          @relation("UserPosts", fields: [authorId], references: [id], onDelete: Cascade)
  images       PostImage[]
  likes        PostLike[]
  saves        PostSave[]
  comments     PostComment[]
  likeCount    Int           @default(0)
  saveCount    Int           @default(0)
  commentCount Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([createdAt(sort: Desc)])
  @@index([authorId])
  @@map("Post")
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("PostLike")
}

model PostSave {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("PostSave")
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  userName  String?
  content   String   @db.VarChar(1000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, createdAt(sort: Desc)])
  @@index([userId])
  @@map("PostComment")
}

model PostImage {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  url       String
  key       String
  createdAt DateTime @default(now())

  @@index([postId])
  @@map("PostImage")
}

model Announcement {
  id             String       @id @default(cuid())
  title          String
  content        String
  authorId       String
  author         User         @relation("UserAnnouncements", fields: [authorId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isPinned       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([createdAt(sort: Desc)])
  @@index([organizationId])
  @@index([authorId])
  @@map("Announcement")
}

// ─────────────────────────────────────────────────────────────────────────────
// Schedule Exchange
// ─────────────────────────────────────────────────────────────────────────────

enum GameRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CONFIRMED
  CANCELLED
}

model SchedulePost {
  id              String   @id @default(cuid())
  userId          String
  workbookId      String
  sport           String
  level           String
  gender          String
  seasonStart     DateTime
  seasonEnd       DateTime
  isActive        Boolean  @default(true)
  excludeWeekends Boolean  @default(false)
  excludedDates   Json     @default("[]")  // Array of ISO date strings manually hidden
  title           String?                  // Optional custom title for the post
  description     String?                  // Optional description / notes for other ADs
  postedAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User          @relation("UserSchedulePosts", fields: [userId], references: [id], onDelete: Cascade)
  workbook     GamesWorkbook @relation(fields: [workbookId], references: [id], onDelete: Cascade)
  gameRequests GameRequest[]

  @@unique([userId, sport, level, gender])
  @@index([userId])
  @@index([workbookId])
  @@index([sport, level, gender])
  @@index([isActive])
  @@map("SchedulePost")
}

model GameRequest {
  id                   String            @id @default(cuid())
  schedulePostId       String
  requesterUserId      String
  ownerUserId          String
  availableDate        DateTime
  availableTimeWindow  String?
  sport                String
  level                String
  gender               String
  isHomeForRequester   Boolean
  note                 String?
  status               GameRequestStatus @default(PENDING)
  confirmedByOwner     Boolean           @default(false)
  confirmedByRequester Boolean           @default(false)
  syncedToWorkbookId   String?
  syncedGameId         String?
  readByOwner          Boolean           @default(false)
  readByRequester      Boolean           @default(false)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  schedulePost SchedulePost @relation(fields: [schedulePostId], references: [id], onDelete: Cascade)
  requester    User         @relation("GameRequestRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  owner        User         @relation("GameRequestOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, status])
  @@index([requesterUserId, status])
  @@index([schedulePostId])
  @@index([createdAt])
  @@map("GameRequest")
}
