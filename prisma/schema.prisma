generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String                    @id @default(cuid())
  email                      String                    @unique
  name                       String?
  phone                      String?                   @unique
  role                       UserRole                  @default(ATHLETIC_DIRECTOR)
  image                      String?
  avatarKey                  String?
  emailVerified              DateTime?
  hashedPassword             String?
  resetToken                 String?
  resetTokenExpiry           DateTime?
  schoolName                 String?
  teamName                   String?
  stripeCustomerId           String?
  plan                       String?
  priceId                    String?
  planProductId              String?
  planLookupKey              String?
  planNickname               String?
  trialEnd                   DateTime?
  hasReceivedFreeTrial       Boolean                   @default(false)
  cancellationDate           DateTime?
  deletionScheduledAt        DateTime?
  googleCalendarRefreshToken String?
  googleCalendarAccessToken  String?
  calendarTokenExpiry        DateTime?
  googleCalendarId           String?
  googleCalendarEmail        String?
  city                       String?
  lastLoginAt                DateTime?
  lastLoginDate              DateTime?
  dailyLoginCount            Int                       @default(0)
  organizationId             String
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  autoCalendarSyncEnabled    Boolean                   @default(false)
  aiSchedulerEnabled         Boolean                   @default(false)
  aiTravelTimesEnabled       Boolean                   @default(false)
  aiEmailGenerationEnabled   Boolean                   @default(false)
  isDisabled                 Boolean                   @default(false)
  disabledAt                 DateTime?
  disableReason              String?
  isMemberAccess             Boolean                   @default(false)
  schoolAddress              String?
  signaturePhone             String?
  signatureWebsite           String?
  signatureLogoUrl           String?
  signatureText              String?
  costBudgetEnabled          Boolean                   @default(false)
  monthlyBudget              Float?
  scoreTrackerEnabled        Boolean                   @default(false)
  hideChatMenu               Boolean                   @default(false)
  hidePostsMenu              Boolean                   @default(false)
  hideParentsMenu            Boolean                   @default(false)
  hideFindGamesMenu          Boolean                   @default(true)
  schoolDistrict             String?
  dismissedTips              Json                      @default("[]")
  schoolEmail                String?                   @unique
  shareCode                  String?                   @unique
  parentCode                 String?                   @unique
  accounts                   Account[]
  accountDeletionReminders   AccountDeletionReminder[]
  calendarGroupMappings      CalendarGroupMapping[]    @relation("UserCalendarGroupMappings")
  collaborativeMembers       CollaborativeMember[]     @relation("CollaborativeMemberOwner")
  emailCampaigns             EmailCampaign[]           @relation("UserEmailCampaigns")
  emailGroups                EmailGroup[]              @relation("UserEmailGroups")
  emailLogs                  EmailLog[]
  feedbackSubmissions        FeedbackSubmission[]
  games                      Game[]                    @relation("GameCreator")
  gamesWorkbooks             GamesWorkbook[]
  parentAthleteLinks         ParentAthleteLink[]       @relation("ParentLinks")
  parentConversations        Conversation[]            @relation("ParentConversations")
  parentSubscriptions        ParentSubscription[]      @relation("ParentSubscriptions")
  recoveryEmail              RecoveryEmail?
  referredBy                 Referral[]                @relation("UserReferredBy")
  referrals                  Referral[]                @relation("UserReferrals")
  rewardPoints               RewardPoints?             @relation("UserRewardPoints")
  sessions                   Session[]
  subscription               Subscription?             @relation("UserSubscription")
  sentChatMessages           ChatMessage[]             @relation("SentChatMessages")
  supportTickets             SupportTicket[]
  tablePreferences           TablePreference[]
  organization               Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  loginEvents                UserLoginEvent[]
  calendarSyncRequests       CalendarSyncRequest[]     @relation("ParentCalendarSyncRequests")
  emailJobs                  EmailJob[]
  posts                      Post[]                    @relation("UserPosts")
  announcements              Announcement[]            @relation("UserAnnouncements")
  schedulePosts              SchedulePost[]            @relation("UserSchedulePosts")
  ownedGameRequests          GameRequest[]             @relation("GameRequestOwner")
  sentGameRequests           GameRequest[]             @relation("GameRequestRequester")
  adConversationsAsA         AdConversation[]          @relation("AdConvUserA")
  adConversationsAsB         AdConversation[]          @relation("AdConvUserB")
  sentAdMessages             AdMessage[]               @relation("SentAdMessages")

  @@index([organizationId])
  @@map("User")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model StripeWebhookEvent {
  id          String    @id
  type        String
  payload     Json
  status      String    @default("PENDING") // PENDING, PROCESSED, FAILED
  error       String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@map("StripeWebhookEvent")
}

model BackgroundJob {
  id             String    @id @default(cuid())
  type           JobType
  status         JobStatus @default(PENDING)
  payload        Json
  result         Json?
  error          String?
  attempts       Int       @default(0)
  maxAttempts    Int       @default(5)
  nextAttemptAt  DateTime? @default(now())
  lastAttemptAt  DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  userId         String?
  organizationId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, nextAttemptAt])
  @@index([status, createdAt])
  @@index([organizationId])
  @@index([userId])
  @@index([payload])
}

enum JobType {
  EMAIL
  STRIPE_WEBHOOK
  CALENDAR_SYNC
  GAME_IMPORT
  EMAIL_IMPORT
  GAME_REQUEST_CONFIRM
  SCHOOL_DISTRICT_LOOKUP
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model CustomColumn {
  id             String           @id @default(uuid())
  name           String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organizationId String
  workbookId     String?
  type           CustomColumnType @default(TEXT)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workbook       GamesWorkbook?   @relation(fields: [workbookId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name, workbookId])
  @@index([organizationId])
  @@index([workbookId])
}

model TablePreference {
  id          String   @id @default(cuid())
  userId      String
  tableKey    String
  preferences Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tableKey])
}

model GamesWorkbook {
  id                    String                @id @default(cuid())
  name                  String
  sortOrder             Int                   @default(0)
  userId                String
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  games                 Game[]
  customColumns         CustomColumn[]
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendarSyncRequests  CalendarSyncRequest[]
  schedulePosts         SchedulePost[]

  @@unique([userId, sortOrder])
  @@index([userId])
}

model Organization {
  id                     String                @id @default(cuid())
  name                   String
  district               String?
  state                  String?
  timezone               String                @default("America/New_York")
  storageUsageBytes      BigInt                @default(0)
  storageQuotaBytes      BigInt                @default(1073741824)
  lastStorageCalculation DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  connectedParents       ConnectedParent[]
  conversations          Conversation[]
  customColumns          CustomColumn[]
  emailGroups            EmailGroup[]          @relation("OrganizationEmailGroups")
  opponents              Opponent[]
  parentAthleteLinks     ParentAthleteLink[]
  schools                School[]
  teams                  Team[]
  travelSettings         TravelSettings?
  users                  User[]
  venues                 Venue[]
  calendarSyncRequests   CalendarSyncRequest[] @relation("SchoolCalendarSyncRequests")
  announcements          Announcement[]
}

model Sport {
  id     String @id @default(cuid())
  name   String @unique
  season Season
  teams  Team[]
}

model Team {
  id             String       @id @default(cuid())
  name           String
  gender         Gender?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  sportId        String
  organizationId String
  level          String
  awayGames      Game[]       @relation("AwayTeam")
  homeGames      Game[]       @relation("HomeTeam")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sport          Sport        @relation(fields: [sportId], references: [id])

  @@index([organizationId])
  @@index([sportId])
}

model Game {
  id                       String                 @id @default(cuid())
  date                     DateTime
  time                     String?
  status                   GameStatus             @default(SCHEDULED)
  notes                    String?
  location                 String?
  isHome                   Boolean                @default(true)
  travelRequired           Boolean                @default(false)
  busTravel                Boolean                @default(false)
  estimatedTravelTime      Int?
  departureTime            DateTime?
  busCount                 Int?
  travelCost               Float?
  recommendedDepartureTime DateTime?
  recommendedArrivalTime   DateTime?
  actualDepartureTime      DateTime?
  actualArrivalTime        DateTime?
  travelTimeMinutes        Int?
  autoFillBusInfo          Boolean                @default(false)
  calendarSynced           Boolean                @default(false)
  syncInProgress           Boolean                @default(false)
  lastSyncedAt             DateTime?
  googleCalendarEventId    String?
  googleCalendarHtmlLink   String?
  customFields             Json?
  customData               Json?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  homeTeamId               String
  awayTeamId               String?
  venueId                  String?
  opponentId               String?
  createdById              String
  sortOrder                Int                    @default(0)
  isSampleGame             Boolean                @default(false)
  cost                     Float?
  workbookId               String?
  emailLogs                EmailLog[]
  awayTeam                 Team?                  @relation("AwayTeam", fields: [awayTeamId], references: [id])
  createdBy                User                   @relation("GameCreator", fields: [createdById], references: [id], onDelete: Cascade)
  homeTeam                 Team                   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  opponent                 Opponent?              @relation(fields: [opponentId], references: [id])
  venue                    Venue?                 @relation(fields: [venueId], references: [id])
  workbook                 GamesWorkbook?         @relation(fields: [workbookId], references: [id])
  travelRecommendations    TravelRecommendation[]

  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([date])
  @@index([venueId])
  @@index([opponentId])
  @@index([createdById, sortOrder])
  @@index([workbookId])
  // Composite indexes for common multi-column query patterns
  @@index([workbookId, date])             // workbook schedule range queries
  @@index([workbookId, status])           // workbook + status filter (cancel detection)
  @@index([date, status])                 // upcoming games by status across org
  @@index([homeTeamId, date])             // team schedule in date range
}

model Venue {
  id             String       @id @default(cuid())
  name           String
  address        String?
  city           String?
  state          String?
  zipCode        String?
  latitude       Float?
  longitude      Float?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  games          Game[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model EmailLog {
  id                  String      @default(cuid())
  to                  String[]
  cc                  String[]
  subject             String
  body                String
  replyTo             String?
  status              EmailStatus @default(PENDING)
  sentAt              DateTime?
  error               String?
  createdAt           DateTime    @default(now())
  gameIds             String[]    @default([])
  groupId             String?
  campaignId          String?
  recipientCategory   String?
  additionalMessage   String?
  gameId              String?
  sentById            String?
  selectedSchoolNames String[]    @default([])
  visibleColumnIds    String[]    @default([])
  customRecipients    String[]    @default([])
  game                Game?       @relation(fields: [gameId], references: [id])
  sentBy              User?       @relation(fields: [sentById], references: [id], onDelete: Cascade)

  @@id([id, createdAt])
  @@index([gameId])
  @@index([sentById])
  @@index([createdAt])
  @@index([status])
  // Composite indexes for email limit queries (avoids full table scans)
  @@index([status, sentAt])               // global monthly count: WHERE status='SENT' AND sentAt>=...
  @@index([sentById, status, sentAt])     // per-user daily/monthly limit checks
}

model EmailJob {
  id                  String         @id @default(cuid())
  userId              String
  organizationId      String
  subject             String
  body                String
  replyTo             String?
  status              EmailJobStatus @default(PENDING)
  totalCount          Int            @default(0)
  sentCount           Int            @default(0)
  failedCount         Int            @default(0)
  gameIds             String[]       @default([])
  groupId             String?
  campaignId          String?
  recipientCategory   String?
  additionalMessage   String?
  visibleColumnIds    String[]       @default([])
  selectedSchoolNames String[]       @default([])
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipients          EmailRecipient[]

  @@index([userId])
  @@index([organizationId])
  @@index([status])
}

model EmailRecipient {
  id          String               @id @default(cuid())
  jobId       String
  email       String
  status      EmailRecipientStatus @default(PENDING)
  error       String?
  retryCount  Int                  @default(0)
  lastAttempt DateTime?
  job         EmailJob             @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([status])
}

model AccountDeletionReminder {
  id                 String   @id @default(cuid())
  userId             String
  daysBeforeDeletion Int
  sentAt             DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, daysBeforeDeletion])
  @@index([daysBeforeDeletion])
  @@map("AccountDeletionReminder")
}

model SupportTicket {
  id             String              @id @default(cuid())
  ticketNumber   String              @unique
  userId         String?
  name           String
  email          String
  subject        String
  initialMessage String
  description    String?
  status         SupportTicketStatus @default(OPEN)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User?               @relation(fields: [userId], references: [id])

  @@index([userId])
}

model FeedbackSubmission {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  email     String?
  subject   String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Opponent {
  id             String          @id @default(cuid())
  name           String
  mascot         String?
  colors         String?
  contact        String?
  phone          String?
  email          String?
  notes          String?
  sortOrder      Int             @default(0) @map("sort_order")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organizationId String
  games          Game[]
  matchupResults MatchupResult[]
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, sortOrder])
  @@index([organizationId])
}

model MatchupResult {
  id                String   @id @default(cuid())
  organizationScore Int
  opponentScore     Int
  isWin             Boolean
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  opponentId        String
  organizationId    String
  sport             String?
  gender            String?
  level             String?
  opponent          Opponent @relation(fields: [opponentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([opponentId])
  @@index([organizationId, sport, gender, level])
}

model TravelRecommendation {
  id                   String    @id @default(cuid())
  gameId               String
  recommendedDeparture DateTime
  recommendedArrival   DateTime
  travelDuration       Int
  trafficCondition     String?
  weatherCondition     String?
  addedToGame          Boolean   @default(false)
  addedAt              DateTime?
  createdAt            DateTime  @default(now())
  game                 Game      @relation(fields: [gameId], references: [id])

  @@index([gameId])
}

model TravelSettings {
  id                   String       @id @default(cuid())
  organizationId       String       @unique
  autoFillEnabled      Boolean      @default(false)
  defaultBufferMinutes Int          @default(45)
  busLoadingMinutes    Int          @default(15)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EmailGroup {
  id             String          @id @default(uuid())
  name           String
  userId         String
  organizationId String
  createdAt      DateTime        @default(now())
  emails         EmailAddress[]
  campaigns      EmailCampaign[]
  organization   Organization    @relation("OrganizationEmailGroups", fields: [organizationId], references: [id], onDelete: Cascade)
  user           User            @relation("UserEmailGroups", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([userId])
}

model EmailAddress {
  id      String     @id @default(uuid())
  email   String
  groupId String
  group   EmailGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([email, groupId])
  @@index([groupId])
}

model EmailCampaign {
  id        String      @id @default(uuid())
  name      String
  subject   String
  body      String
  groupId   String?
  sentAt    DateTime?
  createdAt DateTime    @default(now())
  userId    String
  group     EmailGroup? @relation(fields: [groupId], references: [id])
  user      User        @relation("UserEmailCampaigns", fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?
  customerId           String?
  customer_email       String?
  planType             PlanType?
  billingCycle         String?
  priceId              String?
  planProductId        String?
  planLookupKey        String?
  planNickname         String?
  status               SubscriptionStatus
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAt             DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  gracePeriodEndsAt    DateTime?
  deletionScheduledAt  DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?
  endedAt              DateTime?
  latestInvoiceId      String?
  lastEventId          String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation("UserSubscription", fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeSubscriptionId])
  @@map("Subscription")
}

model UserLoginEvent {
  id        String   @id @default(cuid())
  userId    String
  timestamp DateTime @default(now())
  ipAddress String?
  city      String?
  region    String?
  country   String?
  success   Boolean  @default(true)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
}

model RecoveryEmail {
  id          String    @id @default(cuid())
  email       String    @unique
  verified    Boolean   @default(false)
  token       String?
  tokenExpiry DateTime?
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id             String         @id @default(cuid())
  referrerUserId String
  referredEmail  String?
  referredUserId String?
  status         ReferralStatus @default(PENDING)
  pointsAwarded  Int            @default(0)
  signedUpAt     DateTime?
  rewardedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  referred       User?          @relation("UserReferredBy", fields: [referredUserId], references: [id])
  referrer       User           @relation("UserReferrals", fields: [referrerUserId], references: [id], onDelete: Cascade)

  @@index([referrerUserId])
  @@index([referredUserId])
  @@index([referredEmail])
}

model RewardPoints {
  id        String   @id @default(cuid())
  userId    String   @unique
  points    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation("UserRewardPoints", fields: [userId], references: [id], onDelete: Cascade)
}

model SignupLog {
  id            String   @id @default(cuid())
  email         String?
  phone         String?
  deletedUserId String?
  deletedAt     DateTime @default(now())
  expiresAt     DateTime
  reason        String?
  createdAt     DateTime @default(now())

  @@index([email])
  @@index([phone])
  @@index([expiresAt])
  @@map("SignupLog")
}

model CalendarGroupMapping {
  id                 String   @id @default(cuid())
  userId             String
  columnName         String
  columnValue        String
  googleCalendarId   String
  googleCalendarName String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation("UserCalendarGroupMappings", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, columnName, columnValue])
  @@index([userId])
  @@map("CalendarGroupMapping")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@map("NewsletterSubscriber")
}

model PartnerRequest {
  id              String        @id @default(cuid())
  fullName        String
  email           String        @unique
  schoolOrCollege String
  status          PartnerStatus @default(PENDING)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@map("PartnerRequest")
}

model WaitlistEntry {
  id              String         @id @default(cuid())
  fullName        String
  email           String         @unique
  schoolOrCollege String
  status          WaitlistStatus @default(PENDING)
  notifiedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status])
  @@map("WaitlistEntry")
}

model GoogleCalendarSyncTracker {
  id            String   @id @default(cuid())
  count         Int      @default(0)
  lastUpdated   DateTime @updatedAt
  lastCountedAt DateTime @default(now())
}

model CollaborativeMember {
  id                   String                       @id @default(cuid())
  userId               String
  email                String
  role                 CollaborativeRole            @default(VIEWER)
  status               CollaborativeStatus          @default(PENDING)
  invitedAt            DateTime                     @default(now())
  acceptedAt           DateTime?
  revokedAt            DateTime?
  revokeReason         String?
  token                String?                      @unique
  emailError           String?
  emailSent            Boolean                      @default(false)
  emailSentAt          DateTime?
  chatAccess           CollaboratorChatAccess?
  chatAccessRequestedAt DateTime?
  chatAccessReviewedAt  DateTime?
  owner                User                         @relation("CollaborativeMemberOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([userId, status])
  @@index([email])
  @@map("CollaborativeMember")
}

model CollaborationAuditLog {
  id             String              @id @default(cuid())
  action         CollaborationAction
  ownerId        String
  targetEmail    String?
  collaboratorId String?
  role           CollaborativeRole?
  details        String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime            @default(now())

  @@index([ownerId, createdAt])
  @@index([action, createdAt])
  @@map("CollaborationAuditLog")
}

model School {
  id                 String              @id @default(cuid())
  name               String
  address            String?
  email              String?
  mascot             String?
  state              String?
  organizationId     String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentAthleteLinks ParentAthleteLink[]
  connectedParents   ConnectedParent[]

  @@index([organizationId])
  @@map("School")
}

model ParentAthleteLink {
  id             String               @id @default(cuid())
  parentUserId   String
  schoolId       String
  schoolEntityId String?
  athleteName    String
  athleteEmail   String?              @unique
  teamName       String?
  sport          String?
  gradeLevel     String?
  status         String               @default("PENDING")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  parent         User                 @relation("ParentLinks", fields: [parentUserId], references: [id], onDelete: Cascade)
  school         Organization         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolEntity   School?              @relation(fields: [schoolEntityId], references: [id])
  subscriptions  ParentSubscription[]

  @@index([parentUserId])
  @@index([schoolId])
  @@index([schoolEntityId])
  @@index([athleteEmail])
  @@map("ParentAthleteLink")
}

model ParentSubscription {
  id                   String            @id @default(cuid())
  parentUserId         String
  parentAthleteLinkId  String
  subscriptionType     String
  status               String            @default("ACTIVE")
  subscribedAt         DateTime          @default(now())
  expiresAt            DateTime?
  notificationsEnabled Boolean           @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  athleteLink          ParentAthleteLink @relation(fields: [parentAthleteLinkId], references: [id], onDelete: Cascade)
  parent               User              @relation("ParentSubscriptions", fields: [parentUserId], references: [id], onDelete: Cascade)

  @@unique([parentUserId, parentAthleteLinkId])
  @@index([parentUserId])
  @@index([parentAthleteLinkId])
  @@map("ParentSubscription")
}

model ConnectedParent {
  id               String              @id @default(cuid())
  email            String              @unique
  fullName         String
  schoolId         String
  schoolEntityId   String?
  phone            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  calendarSynced   Boolean
  membershipStatus SubscriptionStatus?
  parentUserId     String              @unique
  parentUserName   String?
  sportName        String?
  sportLevel       String?
  lastSyncedAt     DateTime?
  school           Organization        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolEntity     School?             @relation(fields: [schoolEntityId], references: [id])

  @@index([schoolId])
  @@index([schoolEntityId])
  @@map("ConnectedParent")
}

model Conversation {
  id            String        @id @default(cuid())
  parentUserId  String
  schoolId      String
  lastMessageAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  parent        User          @relation("ParentConversations", fields: [parentUserId], references: [id], onDelete: Cascade)
  school        Organization  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  messages      ChatMessage[]

  @@unique([parentUserId, schoolId])
  @@index([parentUserId])
  @@index([schoolId])
  @@index([lastMessageAt])
}

model CalendarSyncRequest {
  id               String             @id @default(cuid())
  parentUserId     String
  schoolId         String // Organization ID
  sportName        String // e.g., "Soccer"
  sportLevel       String // e.g., "VARSITY"
  gender           String? // Normalised gender: "boys" | "girls" | "mixed" — set by AD on approval
  spreadsheetId    String? // Legacy / external Google Sheet ID (kept for backward compat)
  workbookId       String? // GamesWorkbook the AD picked to scope this sync — preferred over spreadsheetId
  status           CalendarSyncStatus @default(PENDING)
  googleCalendarId String? // Set when approved
  rejectionReason  String?
  requestedAt      DateTime           @default(now())
  reviewedAt       DateTime?
  reviewedById     String?
  parent           User               @relation("ParentCalendarSyncRequests", fields: [parentUserId], references: [id], onDelete: Cascade)
  school           Organization       @relation("SchoolCalendarSyncRequests", fields: [schoolId], references: [id], onDelete: Cascade)
  workbook         GamesWorkbook?     @relation(fields: [workbookId], references: [id], onDelete: SetNull)

  @@index([parentUserId])
  @@index([schoolId])
  @@index([status])
  @@index([workbookId])
  @@map("CalendarSyncRequest")
}

/**
 * Stores per-parent Google Calendar event IDs for synced games.
 * The Game model's googleCalendarEventId is AD-only; parent event IDs
 * live here so the two sync paths never overwrite each other.
 */
model ParentGameCalendarEvent {
  id                    String   @id @default(cuid())
  parentUserId          String
  gameId                String
  googleCalendarEventId String
  googleCalendarId      String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([parentUserId, gameId])
  @@index([parentUserId])
  @@index([gameId])
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  senderUserId   String
  content        String
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentChatMessages", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderUserId])
  @@index([senderUserId, createdAt])
}

enum AdConvStatus {
  PENDING  // initiator sent first message; awaiting recipient reply to activate
  ACTIVE   // both parties may freely exchange messages
  BLOCKED  // one party has muted the conversation (see blockedByUserId)
}

model AdConversation {
  id              String       @id @default(cuid())
  userAId         String       // lexicographically smaller userId (canonical pair key)
  userBId         String       // lexicographically larger userId
  initiatorId     String       // who sent the very first message
  status          AdConvStatus @default(PENDING)
  blockedByUserId String?      // set when status=BLOCKED
  lastMessageAt   DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  userA           User         @relation("AdConvUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB           User         @relation("AdConvUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages        AdMessage[]

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([lastMessageAt])
  @@map("AdConversation")
}

model AdMessage {
  id             String         @id @default(cuid())
  conversationId String
  senderUserId   String
  content        String         // AES-256-GCM encrypted
  readAt         DateTime?
  deletedAt      DateTime?      // soft-delete; excluded from UI
  createdAt      DateTime       @default(now())
  conversation   AdConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User           @relation("SentAdMessages", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderUserId])
  @@map("AdMessage")
}

