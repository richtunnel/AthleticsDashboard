# Docker Environment Variables Template
# Copy this file to .env and update with your actual values

# ============================================
# Database Configuration
# ============================================
# Connection pool parameters prevent connection slot exhaustion:
# - connection_limit: Maximum number of connections (default: 10, reduced for managed databases)
# - pool_timeout: Maximum time in seconds to wait for a connection (default: 10)
#
# For Docker Compose (using postgres service name)
DATABASE_URL="postgresql://athleticsuser:athleticspass@postgres:5432/athleticsdb?schema=public&connection_limit=10&pool_timeout=20"

# For external database (production)
# DATABASE_URL="postgresql://user:password@your-db-host:5432/dbname?schema=public&connection_limit=10&pool_timeout=20"

# Database credentials (for docker-compose postgres service)
DATABASE_USER=athleticsuser
DATABASE_PASSWORD=athleticspass
DATABASE_NAME=athleticsdb
DATABASE_HOST=postgres
DATABASE_PORT=5432

# ============================================
# NextAuth Configuration
# ============================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Update with your actual domain (or localhost for development)
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================
# Google OAuth & Calendar Integration
# ============================================
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CALENDAR_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CALENDAR_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/calendar-callback"

# Google Maps API (for address autocomplete)
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Google Distance Matrix API (for travel time calculations)
GOOGLE_DISTANCE_API_KEY="your-google-distance-api-key"

# ============================================
# Weather API
# ============================================
# Get key from: https://openweathermap.org/api
OPENWEATHER_API_KEY="your-openweather-api-key"

# ============================================
# Email Service (Resend)
# ============================================
# Get key from: https://resend.com/
NEXT_PUBLIC_RESEND_API_KEY="re_your_NEXT_PUBLIC_RESEND_API_KEY"
EMAIL_FROM="AD Hub <noreply@athleticdirectorhub.com>"

# ============================================
# OpenAI (for AI-powered features)
# ============================================
# Get key from: https://platform.openai.com/
OPENAI_API_KEY="sk-your-openai-api-key"

# ============================================
# Stripe Payment Processing
# ============================================
# Get keys from: https://dashboard.stripe.com/
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# New Stripe Price IDs
STRIPE_STANDARD_PRICE_ID_MO="price_1Sgr0EPoFQ98Rxs6en8iUh5l"
STRIPE_STANDARD_PRICE_ID_YR="price_1SjiuIPoFQ98Rxs6cDAn8CyP"
STRIPE_TEAM_PRICE_ID_MO="price_1SjixuPoFQ98Rxs6SvUYQRXr"
STRIPE_TEAM_PRICE_ID_YR="price_1SjizePoFQ98Rxs6KGfct6Vf"
STRIPE_PLUS_PRICE_ID_MO="price_1Sjj0vPoFQ98Rxs60z0ultaq"
STRIPE_PLUS_PRICE_ID_YR="price_1Sjj1iPoFQ98Rxs62Vmsq848"

# Public Price IDs (needed for frontend)
NEXT_PUBLIC_STRIPE_STANDARD_PRICE_ID_MO="price_1Sgr0EPoFQ98Rxs6en8iUh5l"
NEXT_PUBLIC_STRIPE_STANDARD_PRICE_ID_YR="price_1SjiuIPoFQ98Rxs6cDAn8CyP"
NEXT_PUBLIC_STRIPE_TEAM_PRICE_ID_MO="price_1SjixuPoFQ98Rxs6SvUYQRXr"
NEXT_PUBLIC_STRIPE_TEAM_PRICE_ID_YR="price_1SjizePoFQ98Rxs6KGfct6Vf"
NEXT_PUBLIC_STRIPE_PLUS_PRICE_ID_MO="price_1Sjj0vPoFQ98Rxs60z0ultaq"
NEXT_PUBLIC_STRIPE_PLUS_PRICE_ID_YR="price_1Sjj1iPoFQ98Rxs62Vmsq848"

# Optional: Override trial period in test mode (in days, default: 14)
STRIPE_TEST_TRIAL_DAY="14"
# STRIPE_TEST_TRIAL_DAYS="1"

# ============================================
# Environment
# ============================================
NODE_ENV="production"

# ============================================
# Optional: Adminer Database UI
# ============================================
ADMINER_DEFAULT_SERVER=postgres
